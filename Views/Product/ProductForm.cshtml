@model ProductFormViewModel

<div class="container mt-4">
    <h2>@Model.Title</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            @{
                var formAction = Model.IsEdit ? "Edit" : "Create";
            }
            <form asp-action="@formAction" method="post">
                @if (Model.IsEdit)
                {
                    <input type="hidden" asp-for="ProductId" />
                }

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Product name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select" id="categorySelect">
                        <option value="">-- Select category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Price</label>
                    <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div id="attributesContainer">
                    @if (Model.Attributes.Any())
                    {
                        <h5 class="mt-4">Attributes</h5>
                        @foreach (var attr in Model.Attributes)
                        {
                            <div class="mb-3">
                                <label class="form-label">@attr.Name</label>
                                @{
                                    var selectedVal = Model.SelectedAtributes.ContainsKey(attr.Id)
                                        ? Model.SelectedAtributes[attr.Id].ToString()
                                        : "";
                                }
                                <select name="SelectedAtributes[@attr.Id]" class="form-select">
                                    <option value="">-- Not specified --</option>
                                    @foreach (var val in attr.AttributeValues)
                                    {
                                        var isSelected = val.Value == selectedVal;
                                        <option value="@val.Value" selected="@isSelected">@val.Text</option>
                                    }
                                </select>
                            </div>
                        }
                    }
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
    document.getElementById('categorySelect')?.addEventListener('change', async function () {
        const catId = this.value;
        const container = document.getElementById('attributesContainer');
        if (!catId) { container.innerHTML = ''; return; }

        const resp = await fetch(`/Product/GetAttributesByCategory?categoryId=${catId}`);
        const attrs = await resp.json();

        if (!attrs.length) { container.innerHTML = ''; return; }

        let html = '<h5 class="mt-4">Attributes</h5>';
        attrs.forEach(attr => {
            html += `<div class="mb-3">
                <label class="form-label">${attr.name}</label>
                <select name="SelectedAtributes[${attr.id}]" class="form-select">
                    <option value="">-- Not specified --</option>
                    ${attr.values.map(v => `<option value="${v.valueId}">${v.value}</option>`).join('')}
                </select>
            </div>`;
        });
        container.innerHTML = html;
    });
    </script>
}
