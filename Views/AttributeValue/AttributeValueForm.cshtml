@using PcStoreApp.ViewModels.Attribute
@model AttributeValueFormViewModel

<div class="container mt-4">
    <h2>@Model.Title</h2>
    <hr />

    <div class="row">
        <div class="col-md-4">
            <form asp-action="@(Model.IsEdit ? "EditValue" : "AddValue")" method="post">
                <input type="hidden" asp-for="AttributeId" />
                @if (Model.IsEdit)
                {
                    <input type="hidden" asp-for="ValueId" />
                }

                <div class="mb-3">
                    <label asp-for="Value" class="form-label">Value</label>
                    <input asp-for="Value" class="form-control" />
                    <span asp-validation-for="Value" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Values" asp-route-id="@Model.AttributeId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>