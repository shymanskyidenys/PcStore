@model AttributeValuesListViewModel

<h2>Values of "@Model.AttributeName"</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="AddValue" method="post" class="d-flex gap-2 mb-3">
    <input type="hidden" name="attributeId" value="@Model.AttributeId" />
    <input type="text" name="value" class="form-control" placeholder="New value..." />
    <button type="submit" class="btn btn-primary">Add</button>
</form>

<a asp-action="Index" class="btn btn-outline-secondary mb-3">Back to attributes</a>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Value</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Values)
        {
            <tr>
                <td>@item.ValueId</td>
                <td>@item.Value</td>
                <td>
                    <form asp-action="DeleteValue"
                          method="post"
                          onsubmit="return confirm('Are you sure?')">
                        <input type="hidden" name="id" value="@item.ValueId" />
                        <input type="hidden" name="attributeId" value="@Model.AttributeId" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
