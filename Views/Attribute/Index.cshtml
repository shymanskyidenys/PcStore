@model IEnumerable<PcStoreApp.Models.Attribute>

<h2>Attributes</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<a asp-action="Create" class="btn btn-primary">Add attribute</a>

<table class="table">
    <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Attribute value count</th>
        <th></th>
        <th></th>
        <th></th>
    </thead>
    <tbody>
        @foreach (PcStoreApp.Models.Attribute item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.AttributeValueCount</td>
                <td>
                    <a asp-controller="AttributeValue" asp-action="Index" asp-route-id="@item.Id" class="btn btn-secondary">Values</a>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary">Edit</a>
                </td>
                <td>
                    <form asp-action="Delete"
                          asp-route-id="@item.Id"
                          method="post"
                          onsubmit="return confirm('Are you shure?')">

                        <button type="submit" class="btn btn-secondary">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
